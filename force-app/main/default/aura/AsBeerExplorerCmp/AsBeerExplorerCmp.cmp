<aura:component implements="flexipage:availableForAllPageTypes,force:appHostable" controller="BeerExplorerController">

        <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
        <aura:handler name="beerEvent" event="c:searchEvent" action="{!c.handleBeerSearchEvent}"/>
        <aura:attribute name="beerRecords" type="List"/>

        <div>
                <c:AsHeaderCmp title="Daaru Khana" subtitle="Order Daaru Digitally From Home 🍾"/>
        </div>
        <c:AsBeerSearchCmp/>

        <div>
                <c:BeerListCmp recordList="{!v.beerRecords}"/>
        </div>
</aura:component>