<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <masterLabel>ProductChannel</masterLabel>
    <isExposed>true</isExposed>

    <lightningMessageFields>
        <fieldName>productId</fieldName>
        <description>Product id of the selected product</description>
    </lightningMessageFields>

    <lightningMessageFields>
        <fieldName>productName</fieldName>
        <description>name of the selected product </description>
    </lightningMessageFields>

    <lightningMessageFields>
        <fieldName>productPrice</fieldName>
        <description>price of the product </description>
    </lightningMessageFields>

    <lightningMessageFields>
        <fieldName>productCategory</fieldName>
        <description>category of the product</description>
    </lightningMessageFields>

    <lightningMessageFields>
        <fieldName>action</fieldName>
        <description>'select' when the product clicked , 'clear' when unselected </description>
    </lightningMessageFields>
</LightningMessageChannel>